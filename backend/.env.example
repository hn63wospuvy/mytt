# Tutor backend config (spec §13). Copy to .env and fill in.
PROFILE=local                 # local | cloud

# --- LiveKit transport ---
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_to_at_least_32_bytes_long

# --- LOCAL models (OpenAI-compatible HTTP servers on the Mac) ---
STT_MODEL=nvidia/nemotron-3.5-asr-streaming-0.6b
STT_LANG=vi                   # + auto-detect for code-switch
STT_CHUNK_MS=160
STT_BASE_URL=http://127.0.0.1:8000/v1

LLM_MODEL=mlx-community/Qwen3-8B-4bit
LLM_MAX_TOKENS=256
LLM_BASE_URL=http://127.0.0.1:8082/v1   # 8080 is the token server
LLM_API_KEY=local

TTS_MODEL=pnnbao-ump/VieNeu-TTS
TTS_VOICE=
TTS_BASE_URL=http://127.0.0.1:8001

# --- Web search (local profile) ---
SEARCH_BACKEND=tavily          # tavily | brave | searxng
SEARCH_API_KEY=                # or set SEARXNG_URL for searxng
SEARXNG_URL=http://127.0.0.1:8888

# --- Wake word (Phase 2) ---
WAKEWORD_ENGINE=openwakeword   # openwakeword | porcupine
WAKEWORD_PHRASE=hey tutor

# --- Learning session ---
LEVEL=B1
DB_PATH=tutor.db

# --- Dev: run the loop with no model servers ---
# MOCK_ADAPTERS=1            # all adapters mock
# Per-component overrides (default to MOCK_ADAPTERS): e.g. real LLM, mock STT/TTS
# MOCK_STT=1
# MOCK_TTS=1
# MOCK_SEARCH=1

# --- CLOUD (Phase 3) ---
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=                # empty = plugin default (native-audio)
GEMINI_LANGUAGE=                  # empty = multilingual (native-audio rejects bare "vi")
# Gemini Live "thinking" budget. 0 = OFF → answers immediately (lowest latency);
# a positive number = tokens it may reason before replying (slower, maybe better
# corrections); -1 = leave the model default.
GEMINI_THINKING_BUDGET=1
