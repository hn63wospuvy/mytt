# Cloud-profile compose config. Copy to .env and fill in.
#   cp .env.example .env

# Public WebSocket URL the BROWSER uses to reach LiveKit. It must be reachable
# from the client (not the docker-internal "livekit" name).
#   Local test:   ws://localhost:7880
#   Production:   wss://livekit.your-domain.tld   (TLS terminated at a proxy)
PUBLIC_LIVEKIT_URL=ws://localhost:7880

# LiveKit API credentials — shared by the SFU, the agent worker and the token
# server. CHANGE THE SECRET (>=32 random bytes) before any non-local deploy.
#   openssl rand -hex 32
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=please_change_me_to_a_random_32_byte_secret

# Stateless web app: NO login and NO server-side storage. Each user enters a
# name + their OWN Gemini key in the browser (saved in localStorage); the key is
# forwarded to the agent per connect in the LiveKit room metadata and is never
# persisted server-side. No GOOGLE_CLIENT_ID, APP_SECRET_KEY or GEMINI_API_KEY
# is needed.

# Optional Gemini tuning (blank = sensible defaults).
GEMINI_LIVE_MODEL=
GEMINI_LANGUAGE=
# 0 = thinking off → answers immediately (lowest latency). >0 = reason first.
GEMINI_THINKING_BUDGET=0

# Learning level (A1..C2).
LEVEL=B1
